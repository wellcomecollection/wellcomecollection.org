{
  "id": "series",
  "label": "Story series",
  "repeatable": true,
  "status": true,
  "format": "custom",
  "json": {
    "Story series": {
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "single": "heading1",
          "useAsTitle": true
        }
      },
      "format": {
        "type": "Link",
        "config": {
          "label": "Format",
          "select": "document",
          "customtypes": [
            "article-formats"
          ]
        }
      },
      "color": {
        "type": "Select",
        "config": {
          "label": "Colour",
          "options": [
            "accent.green",
            "accent.purple",
            "accent.salmon",
            "accent.blue"
          ]
        }
      },
      "uid": {
        "type": "UID",
        "config": {
          "label": "uid",
          "placeholder": ""
        }
      },
      "body": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "text": {
              "type": "SharedSlice"
            },
            "standfirst": {
              "type": "SharedSlice"
            },
            "infoBlock": {
              "type": "SharedSlice"
            },
            "quote": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "Schedule": {
      "schedule": {
        "type": "Group",
        "fieldset": "Schedule",
        "config": {
          "fields": {
            "title": {
              "type": "StructuredText",
              "config": {
                "label": "Title",
                "single": "heading1",
                "useAsTitle": true
              }
            },
            "publishDate": {
              "type": "Timestamp",
              "config": {
                "label": "Date to be published"
              }
            }
          }
        }
      }
    },
    "Contributors": {
      "contributors": {
        "type": "Group",
        "fieldset": "Contributors",
        "config": {
          "fields": {
            "role": {
              "type": "Link",
              "config": {
                "label": "Role",
                "select": "document",
                "customtypes": [
                  "editorial-contributor-roles"
                ]
              }
            },
            "contributor": {
              "type": "Link",
              "config": {
                "label": "Contributor",
                "select": "document",
                "customtypes": [
                  "people",
                  "organisations"
                ]
              }
            },
            "description": {
              "type": "StructuredText",
              "config": {
                "multi": "paragraph,hyperlink,strong,em",
                "label": "Contributor description override"
              }
            }
          }
        }
      },
      "contributorsTitle": {
        "type": "StructuredText",
        "config": {
          "single": "heading1",
          "label": "Contributors heading override"
        }
      }
    },
    "Promo": {
      "promo": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "editorialImage": {
              "type": "Slice",
              "fieldset": "Editorial image",
              "config": {
                "label": "Editorial image"
              },
              "non-repeat": {
                "caption": {
                  "type": "StructuredText",
                  "config": {
                    "single": "paragraph",
                    "label": "Promo text"
                  }
                },
                "image": {
                  "type": "Image",
                  "config": {
                    "label": "Promo image",
                    "thumbnails": [
                      {
                        "name": "32:15",
                        "width": 3200,
                        "height": 1500
                      },
                      {
                        "name": "16:9",
                        "width": 3200,
                        "height": 1800
                      },
                      {
                        "name": "square",
                        "width": 3200,
                        "height": 3200
                      }
                    ]
                  }
                },
                "link": {
                  "type": "Text",
                  "config": {
                    "label": "Link override"
                  }
                }
              }
            }
          }
        }
      }
    },
    "Metadata": {
      "metadataDescription": {
        "type": "StructuredText",
        "config": {
          "single": "paragraph,hyperlink,strong,em",
          "label": "Metadata description"
        }
      }
    },
    "Content relationships": {
      "seasons": {
        "type": "Group",
        "fieldset": "Seasons",
        "config": {
          "fields": {
            "season": {
              "type": "Link",
              "config": {
                "label": "Season",
                "select": "document",
                "customtypes": [
                  "seasons"
                ],
                "placeholder": "Select a Season"
              }
            }
          }
        }
      }
    },
    "Overrides": {
      "publishDate": {
        "type": "Timestamp",
        "config": {
          "label": "Override published date",
          "placeholder": ""
        }
      }
    }
  }
}
