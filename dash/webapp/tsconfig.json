{
  "extends": "../../config/tsconfig-base",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],  // Dom ones needed in this subrepo for Docker build
    "module": "esnext",
    "moduleResolution": "node", // Forced by NextJs on build
    "baseUrl": ".",
    "paths": {
      "@weco/dash/*": ["./*"]
    }
  },
  "ts-node": {
    "preferTsExts": true
  }
}
